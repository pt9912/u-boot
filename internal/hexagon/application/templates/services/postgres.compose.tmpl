image: postgres:16-alpine
environment:
  POSTGRES_USER: ${POSTGRES_USER:-postgres}
  POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-CHANGEME_POSTGRES_PASSWORD}
  POSTGRES_DB: ${POSTGRES_DB:-postgres}
volumes:
  - postgres-data:/var/lib/postgresql/data
ports:
  - "5432:5432"
healthcheck:
  # $$ escapes one $ at the Compose layer; the resulting
  # ${POSTGRES_USER:-postgres} is expanded by the container shell at
  # healthcheck runtime, which sees the env var set by the
  # environment: block above (or its CHANGEME-style default).
  test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER:-postgres}"]
  interval: 10s
  timeout: 5s
  retries: 5
