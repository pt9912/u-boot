// BEGIN U-BOOT MANAGED BLOCK: init
{
  "name": "{{.Name}}",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
{{- if .ForwardPorts}}
  "forwardPorts": [{{range $i, $p := .ForwardPorts}}{{if $i}}, {{end}}{{$p}}{{end}}],
{{- end}}
{{- if .Features}}
  "features": {
{{- range $i, $f := .Features}}
{{- if $i}},{{end}}
    "{{$f.Source}}:{{$f.Version}}": {}
{{- end}}
  },
{{- end}}
  "remoteUser": "vscode"
}
// END U-BOOT MANAGED BLOCK: init
